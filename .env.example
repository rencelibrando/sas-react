# ── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend (Express) ───────────────────────────────────────────────────────
PORT=3001
GMAIL_USER=
GMAIL_PASS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# Comma-separated list of allowed origins for CORS. Leave default for local dev.
FRONTEND_BASE_URL=http://localhost:5173

# Firebase Admin SDK credentials:
# - Local dev can use ./serviceAccountKey.json (gitignored — never commit).
# - Render/production should use FIREBASE_SERVICE_ACCOUNT_JSON containing the
#   full service account JSON on one line.
