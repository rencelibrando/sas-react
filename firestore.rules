rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && currentUserDoc().role == 'Admin';
    }

    function isOrganizationUser() {
      // An "organization user" is any authenticated user that belongs to an
      // organization — i.e. their user doc has a non-empty organizationId and
      // is not the Admin role. role values are org types like "ISG"/"CSG"/"AO".
      return isAuthenticated()
          && currentUserDoc().role != 'Admin'
          && currentUserDoc().organizationId is string
          && currentUserDoc().organizationId.size() > 0;
    }

    // ISG has special visibility over all activity proposals
    function isISG() {
      return isOrganizationUser()
          && get(/databases/$(database)/documents/organizations/$(currentUserDoc().organizationId)).data.type == 'ISG';
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && currentUserDoc().organizationId == orgId;
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users read their own doc; admins read all; unauthenticated allowed for
      // getUserByEmail() during forgot-password flow
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin())
                  || !isAuthenticated();

      // Org users and admins create user docs (admin creates org accounts)
      allow create: if isAuthenticated()
                    && (
                      (request.auth.uid == userId && request.resource.data.userId == userId)
                      || isAdmin()
                    );

      // Users update their own doc (not the role field); admins update any
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId
         && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── organizations ──────────────────────────────────────────────────────
    match /organizations/{organizationId} {
      allow read:             if true; // needed before login for org lookups
      allow create, update, delete: if isAdmin();
    }

    // ── equipment (borrowing catalog) ──────────────────────────────────────
    // Admin-managed catalog of borrowable items. Any authenticated user may
    // read it (requesters need it for the item picker); only admins write.
    match /equipment/{equipmentId} {
      allow read:                   if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── documents ─────────────────────────────────────────────────────────
    match /documents/{documentId} {
      function parentDoc() {
        return get(/databases/$(database)/documents/documents/$(documentId)).data;
      }

      function canReadParentDoc() {
        return isAuthenticated() && (
          isAdmin()
          || (isOrganizationUser()
              && parentDoc().organizationId != null
              && belongsToOrg(parentDoc().organizationId))
          || (isISG() && parentDoc().documentType == 'activity_proposal')
          || (parentDoc().direction == 'outgoing' && parentDoc().status == 'released')
        );
      }

      allow read: if isAuthenticated() && (
        isAdmin()
        // Org users read their own org's documents
        || (isOrganizationUser()
            && resource.data.organizationId != null
            && belongsToOrg(resource.data.organizationId))
        // ISG reads all activity proposals (pipeline visibility)
        || (isISG() && resource.data.documentType == 'activity_proposal')
        // Anyone authenticated can read released outgoing docs (Memorandums)
        || (resource.data.direction == 'outgoing' && resource.data.status == 'released')
      );

      allow create: if isAuthenticated() && (
        // Org user submitting an incoming document for their own org
        (isOrganizationUser()
         && request.resource.data.organizationId != null
         && belongsToOrg(request.resource.data.organizationId)
         && request.resource.data.submittedBy == request.auth.uid
         && request.resource.data.status == 'pending')
        // Admin creating an outgoing document (Memorandum, endorsement letter)
        || (isAdmin() && request.resource.data.direction == 'outgoing')
      );

      // Admins change status/assignment; ISG can advance the pipeline on activity proposals;
      // the requesting org may upload revisions to their own proposal (touching only the
      // revision-related fields). Org users may also resubmit a returned equipment
      // borrowing request — restricted to their own doc and only while status is
      // currently `returned_for_revision`.
      allow update: if isAdmin()
                    || (isISG() && resource.data.documentType == 'activity_proposal')
                    || (
                      resource.data.documentType == 'activity_proposal'
                      && isOrganizationUser()
                      && resource.data.organizationId != null
                      && belongsToOrg(resource.data.organizationId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'files', 'revisionCount', 'dateLastRevised', 'lastUpdated',
                        'additionalRequests', 'updatedBy'
                      ])
                    )
                    || (
                      resource.data.documentType == 'equipment_request'
                      && resource.data.status == 'returned_for_revision'
                      && isOrganizationUser()
                      && resource.data.submittedBy == request.auth.uid
                      && belongsToOrg(resource.data.organizationId)
                      && request.resource.data.status == 'pending'
                    );
      allow delete: if isAdmin();

      // ── comments subcollection ─────────────────────────────────────────
      // Inline reviewer comments anchored to a region of a PDF file.
      //
      // Stage-scoped privacy: on activity proposals, comment authorship is
      // gated by who currently "owns" the stage. Only the submitter, the
      // SAS Admin during SAS-controlled stages, and ISG during ISG-controlled
      // stages can post new comments or append replies. Tokenized offices
      // (VPAA/OP/FMS/Procurement) author through the backend via the Admin
      // SDK, bypassing these rules.
      match /comments/{commentId} {
        function isOrgForParent() {
          return isOrganizationUser()
              && parentDoc().organizationId != null
              && belongsToOrg(parentDoc().organizationId);
        }

        function isActivityProposal() {
          return parentDoc().documentType == 'activity_proposal';
        }

        function parentStage() {
          return parentDoc().pipeline.currentStage;
        }

        function isSASAtSASStage() {
          return isAdmin()
              && parentDoc().pipeline != null
              && (parentStage() == 'sas_review' || parentStage() == 'sas_release');
        }

        function isISGAtGatekeeperStage() {
          return isISG()
              && parentDoc().pipeline != null
              && (parentStage() == 'isg_endorsement' || parentStage() == 'isg_distribution');
        }

        function canAuthorOnParent() {
          // For activity proposals: stage-scoped. For other doc types: keep
          // the original permissive rule (any authorized reader can author).
          return isActivityProposal()
            ? (isOrgForParent() || isSASAtSASStage() || isISGAtGatekeeperStage())
            : canReadParentDoc();
        }

        // Anyone authorized to read the parent document can read its comments
        allow read: if canReadParentDoc();

        // Author must be allowed by the stage-scoped rule and must own the
        // authorUid they're stamping on the doc.
        allow create: if canAuthorOnParent()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.requirementKey is string
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0;

        // Update permissions:
        //   - Admin can do anything
        //   - Comment author can edit/delete their own
        //   - Any current stage-authorized author may append a reply
        //     (only `replies` field changes)
        //   - The requesting org may bulk-resolve via revision (writes `resolved` +
        //     `resolvedByRevision` together)
        //   - Any authorized reader can toggle ONLY the `resolved` flag
        allow update: if canReadParentDoc() && (
          isAdmin()
          || resource.data.authorUid == request.auth.uid
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
            && canAuthorOnParent()
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved', 'resolvedByRevision'])
            && isOrgForParent()
            && request.resource.data.resolved == true
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved'])
        );

        allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      }
    }

    // ── documentStatusHistory ──────────────────────────────────────────────
    match /documentStatusHistory/{historyId} {
      allow read: if isAuthenticated() && (
        isAdmin()
        || (isOrganizationUser()
            && resource.data.documentId != null
            && belongsToOrg(
                 get(/databases/$(database)/documents/documents/$(resource.data.documentId)).data.organizationId
               ))
        || (isISG()
            && get(/databases/$(database)/documents/documents/$(resource.data.documentId)).data.documentType == 'activity_proposal')
      );

      // Org users create the initial "pending" history entry on submission;
      // org users also write a no-status-change entry when uploading a revision to their own proposal;
      // ISG creates history entries when acting on activity proposals
      allow create: if isAdmin()
                    || (isOrganizationUser()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.changedBy == request.auth.uid
                        && request.resource.data.previousStatus == null)
                    || (isOrganizationUser()
                        && request.resource.data.changedBy == request.auth.uid
                        && request.resource.data.status == request.resource.data.previousStatus
                        && request.resource.data.documentId is string
                        && belongsToOrg(
                             get(/databases/$(database)/documents/documents/$(request.resource.data.documentId)).data.organizationId
                           ))
                    // Equipment request resubmission: org user flips status from
                    // returned_for_revision back to pending on their own request.
                    || (isOrganizationUser()
                        && request.resource.data.status == 'pending'
                        && request.resource.data.previousStatus == 'returned_for_revision'
                        && request.resource.data.changedBy == request.auth.uid
                        && request.resource.data.documentId is string
                        && belongsToOrg(
                             get(/databases/$(database)/documents/documents/$(request.resource.data.documentId)).data.organizationId
                           ))
                    || (isISG()
                        && request.resource.data.changedBy == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    // ── documentCounters ──────────────────────────────────────────────────
    // Org users need read+write for the Firestore transaction that generates
    // their incoming document number at submission time.
    match /documentCounters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // ── systemCounters ─────────────────────────────────────────────────────
    // Admins write (Memorandum number, org number); org users read org number
    // if needed, admins write when creating orgs/outgoing docs.
    match /systemCounters/{counterId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin() || isOrganizationUser(); // transaction on submission
    }

    // ── officeProfiles ─────────────────────────────────────────────────────
    match /officeProfiles/{officeId} {
      allow read:             if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ── reviewTokens ───────────────────────────────────────────────────────
    // Public read: tokenized review links are consumed without portal login.
    // Application layer validates token authenticity and expiry.
    match /reviewTokens/{tokenId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── otps ───────────────────────────────────────────────────────────────
    match /otps/{email} {
      allow read, write: if true;
    }

    // ── authActivityLog ────────────────────────────────────────────────────
    // Append-only auth event log for admin visibility (logins, logouts, OTPs,
    // password resets, account creation). Reads are admin-only. Writes are
    // open for "create" with shape validation — some events (login_failed,
    // otp_failed, otp_sent during forgot-password) must be writable without
    // an authenticated session. Updates and deletes are forbidden.
    match /authActivityLog/{entryId} {
      allow read: if isAdmin();

      allow create: if request.resource.data.type is string
                    && request.resource.data.type in [
                         'login_success', 'login_failed', 'logout',
                         'google_login_success', 'google_login_failed',
                         'otp_sent', 'otp_verified', 'otp_failed',
                         'password_reset_success', 'password_reset_failed',
                         'account_created'
                       ]
                    && request.resource.data.success is bool
                    && request.resource.data.timestamp == request.time;

      allow update, delete: if false;
    }

    // ── reports ────────────────────────────────────────────────────────────
    // Post-activity report obligations tied to an approved activity proposal.
    // Created by the system on proposal distribution (createReportRequirements);
    // submitted (file uploaded) by the owning org; reviewed by admins.
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        isAdmin()
        || (isOrganizationUser()
            && resource.data.organizationId != null
            && belongsToOrg(resource.data.organizationId))
      );

      // Creation happens client-side from service layer after ISG distribution.
      // Require shape integrity and the creator to be authenticated.
      allow create: if isAuthenticated()
                    && request.resource.data.proposalId is string
                    && request.resource.data.organizationId is string
                    && request.resource.data.reportType is string
                    && request.resource.data.status == 'pending';

      // Owning org may upload/replace their report file (writes touch only
      // submission-related fields); admins may review/update anything.
      allow update: if isAdmin()
                    || (
                      isOrganizationUser()
                      && resource.data.organizationId != null
                      && belongsToOrg(resource.data.organizationId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'status', 'submittedAt', 'submittedBy', 'file',
                        'revisionCount', 'lastUpdated',
                        'reviewedAt', 'reviewedBy', 'reviewRemarks'
                      ])
                      && request.resource.data.status in ['submitted', 'late']
                    );

      allow delete: if isAdmin();
    }

    // ── notifications ──────────────────────────────────────────────────────
    // In-app notifications. Each doc targets a single recipient. Reads are
    // limited to that recipient; the recipient (or an admin) may flip
    // `isRead`. Creation is permitted by authenticated callers — the
    // service layer fans out from event sources.
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isAdmin() || resource.data.recipientId == request.auth.uid
      );

      allow create: if isAuthenticated()
                    && request.resource.data.recipientId is string
                    && request.resource.data.type is string
                    && request.resource.data.isRead == false;

      // Recipient (or admin) may mark as read; nothing else may change.
      allow update: if isAuthenticated() && (
        isAdmin()
        || (
          resource.data.recipientId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
        )
      );

      allow delete: if isAdmin();
    }

    // ── Default deny ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
